# -------------------------------------------------------------
# 耗材智能管理助手 - 环境变量配置示例 (.env.example)
#
# 请将此文件复制并重命名为 `.env.local`，然后填入你的真实参数。
# 切勿将真实的 `.env.local` 提交到版本库！
# -------------------------------------------------------------

# [必须] 如果需要启用自然语言识别聊天改数，请提供大模型 API Key。
# 若留空，系统将退化为使用有限的本地正则表达式规则。
GENAI_API_KEY="your-api-key-here"

# [可选] 大模型的名称。
# 例如：deepseek-pro, gpt-4o, claude-3-5-sonnet 等，默认为 deepseek-pro
GENAI_MODEL="deepseek-pro"

# [可选] 大模型调用的模式。
# 支持 completion (用于标准对话模型) 或 response (用于支持 structured output 的模型)
GENAI_MODE="completion"

# [可选] API 基础 URL 覆盖。如果不使用官方源或做了本地转发，可在此修改。
GENAI_BASE_URL=""

# [可选] API 调用的最大超时时间（秒），默认 10 秒。
GENAI_TIMEOUT=10
